# Copy this to .env.production on your server and fill in every value.
# NEVER commit .env.production to git.

# Postgres password (used by both the postgres container and the backend)
POSTGRES_PASSWORD=change-me-strong-random-password

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me

# bcrypt hash of your login password — generate with:
#   python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
PASSWORD_HASH=

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# Your server's public IP or domain (used for CORS)
# Example bare IP:    http://1.2.3.4
# Example domain:     https://yourdomain.com
CORS_ORIGINS=http://YOUR_SERVER_IP

# Leave these as-is for production
ENVIRONMENT=production
DEBUG=false
