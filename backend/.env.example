# Copy to backend/.env and fill in. Never commit the real .env.

ENVIRONMENT=development
DEBUG=true

# Google Cloud SQL (PostgreSQL).
# Local dev: run the Cloud SQL Auth Proxy and point at localhost, or use a local Postgres.
DATABASE_URL=postgresql+psycopg2://verbatim:verbatim@localhost:5432/verbatim

# Single-user auth
JWT_SECRET=change-me-in-production

# Owner user password (bcrypt hash). Generate with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
PASSWORD_HASH=

# Anthropic Claude
ANTHROPIC_API_KEY=
MODEL_PLANNING=claude-opus-4-8
MODEL_FAST=claude-sonnet-4-6
