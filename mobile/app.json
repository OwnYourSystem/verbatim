{
  "expo": {
    "name": "Verbatim",
    "slug": "verbatim",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ownyoursystem.verbatim"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.ownyoursystem.verbatim"
    },
    "scheme": "verbatim",
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
